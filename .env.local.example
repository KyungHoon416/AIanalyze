# 이 파일을 복사해서 .env.local 로 저장한 뒤 실제 키를 넣으세요.
# .env.local 은 .gitignore 에 포함되어 있어 깃허브에 올라가지 않습니다.
# 발급: https://aistudio.google.com/apikey

GEMINI_API_KEY=

# 선택: 사용할 Gemini 모델 (기본값 gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# 선택: 광고 제안서 PPT용 AI 이미지 생성 모델 (기본값 gemini-2.5-flash-image)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
